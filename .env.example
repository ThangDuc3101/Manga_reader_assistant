# Roboflow API Configuration Template
# ====================================
# 
# This is a template file showing how to configure the Manga Reader Assistant.
# Copy this file to .env and fill in your actual values.
# 
# DO NOT commit .env to git - it contains your API key!
# The .env file is listed in .gitignore for your protection.

# Required: Your Roboflow API Key
# Get it for free at: https://roboflow.com/settings/api
ROBOFLOW_API_KEY=[REDACTED:api-key]

# Optional: Roboflow Model Name
# Default: manga-bubble-detect (trained specifically for manga)
# ROBOFLOW_MODEL=manga-bubble-detect

# Optional: Roboflow Model Version
# Default: 1
# ROBOFLOW_VERSION=1

# Optional: Disable Roboflow and use YOLOv8s instead
# If set to False, app will use YOLOv8s base model (no setup needed)
# USE_ROBOFLOW=True

# Optional: Enable offline mode (use cached model, no API calls)
# Set to True after first successful model download
# OFFLINE_MODE=False
