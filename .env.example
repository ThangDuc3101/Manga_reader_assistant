# Roboflow API Configuration Template
# ====================================
# 
# This is a template file showing how to configure the Manga Reader Assistant.
# Copy this file to .env and fill in your actual values.
# 
# DO NOT commit .env to git - it contains your API key!
# The .env file is listed in .gitignore for your protection.

# Required: Your Roboflow API Key
# Get it for free at: https://roboflow.com/settings/api
ROBOFLOW_API_KEY=[REDACTED:api-key]

# Optional: Roboflow Model Name
# Default: manga-bubble-detect (trained specifically for manga)
# ROBOFLOW_MODEL=manga-bubble-detect

# Optional: Roboflow Model Version
# Default: 1
# ROBOFLOW_VERSION=1

# Optional: Disable Roboflow and use YOLOv8s instead
# If set to False, app will use YOLOv8s base model (no setup needed)
# USE_ROBOFLOW=True

# Optional: Enable offline mode (use cached model, no API calls)
# Set to True after first successful model download
# OFFLINE_MODE=False

# ============================================================================
# Translation API Settings (Phase 2, Task 3)
# ============================================================================

# Use Google Cloud Translation API (set to true for production)
# Requires: Google Cloud project setup
# USE_GOOGLE_CLOUD_API=false

# Google Cloud project ID (only needed if USE_GOOGLE_CLOUD_API=true)
# GOOGLE_CLOUD_PROJECT_ID=your-project-id-here

# Path to Google Cloud credentials JSON file (only needed if USE_GOOGLE_CLOUD_API=true)
# How to create: https://cloud.google.com/docs/authentication/getting-started
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json

# Retry settings (exponential backoff)
# How many times to retry on API failure (1s, 2s, 4s waits)
# TRANSLATION_MAX_RETRIES=3
# TRANSLATION_RETRY_BACKOFF=1.0

# Cache settings (local translation cache for faster repeated translations)
# ENABLE_TRANSLATION_CACHE=true
# CACHE_SIZE_LIMIT=10000
